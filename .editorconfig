# EditorConfig helps maintain consistent coding styles
# for multiple developers working on the same project across various editors and IDEs.
# https://editorconfig.org

root = true

# All files
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JavaScript files
[*.js]
indent_size = 2
max_line_length = 100

# CSS files
[*.css]
indent_size = 2

# HTML files
[*.html]
indent_size = 2

# Docker files
[Dockerfile*]
indent_size = 4
